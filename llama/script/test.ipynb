   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "W = nn.Linear(3, 5, bias=False)\n",
    "print(W.weight.shape)\n",
    "x = torch.randn(2, 4, 3)\n",
    "y = W(x)\n",
    "print(y.shape)\n",
    "Weight = W.weight\n",
    "yy = x @ Weight.T\n",
    "print(torch.allclose(y, yy))"
   ]
  }
